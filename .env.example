# Groq API Key — get free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# MongoDB connection string
# For MongoDB Atlas (recommended): mongodb+srv://user:pass@cluster.mongodb.net/sales_intel
# For local MongoDB: mongodb://localhost:27017
MONGODB_URI=mongodb://localhost:27017

# Database name
DB_NAME=sales_intelligence

# Google Sheets CRM (optional, free via Google Service Account)
# Setup: See README section 'Setting up Google Sheets CRM'
# 1. Go to console.cloud.google.com → Create project → Enable Sheets API
# 2. Create Service Account → Download JSON key → save as google_credentials.json
# 3. Share your Google Sheet with the service account email
GOOGLE_SHEETS_CREDENTIALS=google_credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# WhatsApp Bot via Twilio Sandbox (free tier available)
# 1. Sign up at https://www.twilio.com/try-twilio
# 2. Go to Console → Messaging → Try it out → Send a WhatsApp message
# 3. Note your Sandbox keyword (e.g. "join apple-sauce")
# 4. Copy Account SID and Auth Token from the Console Dashboard
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
